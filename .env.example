# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY
CLERK_SECRET_KEY=sk_test_YOUR_KEY

# Clerk routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# REST Countries API (no key needed)
NEXT_PUBLIC_REST_COUNTRIES_API=https://restcountries.com/v3.1

# Pexels API (free, https://www.pexels.com/api/)
PEXELS_API_KEY=your-pexels-key

# OpenTripMap API (free, https://dev.opentripmap.org)
OPENTRIPMAP_API_KEY=your-opentripmap-key
